@page
@model number_system_calculator_KDA.Pages.BasketModel
@{
}
<body>
    <div class="container mt-4">
        <div class="card shadow">
            <!-- Заголовок корзины -->
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Ваша корзина</h4>
            </div>

            <div class="card-body">
                @if (!Model.Baskets.Any())
                {
                    <div class="alert alert-info text-center">
                        Ваша корзина пуста
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var basketItem in Model.Baskets)
                        {
                            <div class="list-group-item">
                                <div class="row align-items-center">
                                    <div class="col-md-3">
                                        <h5 class="mb-1">@basketItem.Dish.Title</h5>
                                    </div>
                                    <div class="col-md-2">
                                        <!-- Форма для обновления количества -->
                                        <form method="post" asp-page-handler="UpdateQuantity">
                                            <input type="hidden" name="id" value="@basketItem.Id" />
                                            <input type="number" 
                                                   name="quantity"
                                                   value="@basketItem.Quantity"
                                                   min="1"
                                                   max="100"
                                                   class="form-control"
                                                   onchange="this.form.submit()">
                                        </form>
                                    </div>
                                    <div class="col-md-2">
                                        <span class="text-muted">@basketItem.Price.ToString("C")</span>
                                    </div>
                                    <div class="col-md-2">
                                        <strong>@basketItem.Sum.ToString("C")</strong>
                                    </div>
                                    <div class="col-md-3 text-end">
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@basketItem.Id">
                                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-trash"></i> Удалить
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Блок "Итого" -->
                    <div class="mt-4 p-3 bg-light rounded">
                        <div class="row">
                            <div class="col-md-8 text-end">
                                <h5 class="mb-0">Итого:</h5>
                            </div>
                            <div class="col-md-4">
                                <h4 class="text-primary mb-0">
                                    @Model.Baskets.Sum(b => b.Sum).ToString("C")
                                </h4>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Футер с кнопками -->
            <div class="card-footer bg-transparent">
                <div class="d-flex justify-content-between">
                    @if (Model.Baskets.Any())
                    {
                        <form method="post" asp-page-handler="Clear">
                            <button type="submit" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Очистить корзину
                            </button>
                        </form>

                       <form method="post" asp-page-handler="Order">
    <button type="submit" class="btn btn-primary">
        Оформить заказ
    </button>
</form>
                    }
                    else
                    {
                        <a class="btn btn-primary" asp-page="/UserDishs">Вернуться в меню</a>
                    }
                </div>
            </div>
        </div>
    </div>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .list-group-item {
            padding: 1.25rem;
            border-left: 0;
            border-right: 0;
        }
        .list-group-item:first-child {
            border-top: 0;
        }
        .list-group-item:last-child {
            border-bottom: 0;
        }
        .card {
            border-radius: 0.5rem;
        }
    </style>

</body>

