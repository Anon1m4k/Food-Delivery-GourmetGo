@page
@model number_system_calculator_KDA.Pages.BasketModel
@{
}
<body>
    <div class="container mt-4">
        <div class="card shadow-lg">
            <!-- Заголовок корзины -->
            <div class="card-header bg-gradient-mint text-light">
                <h4 class="mb-0"><i class="fas fa-shopping-basket me-2"></i>Ваша корзина</h4>
            </div>

            <div class="card-body p-0">
                @if (!Model.Baskets.Any())
                {
                    <div class="alert alert-mint text-center m-4">
                        <i class="fas fa-cart-arrow-down fa-2x mb-3"></i>
                        <p class="h5">Ваша корзина пуста</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var basketItem in Model.Baskets)
                        {
                            <div class="list-group-item basket-item py-3">
                                <div class="row align-items-center g-3">
                                    <!-- Название блюда -->
                                    <div class="col-md-4">
                                        <h5 class="mb-1 text-dark">@basketItem.Dish.Title</h5>
                                        <small class="text-muted">@basketItem.Dish.Structure</small>
                                    </div>

                                    <!-- Количество -->
                                    <div class="col-md-3">
                                        <form method="post" asp-page-handler="UpdateQuantity">
                                            <div class="input-group">
                                                <input type="hidden" name="id" value="@basketItem.Id" />
                                                <input type="number"
                                                       name="quantity"
                                                       value="@basketItem.Quantity"
                                                       min="1"
                                                       max="100"
                                                       class="form-control form-control-mint"
                                                       onchange="this.form.submit()">
                                                <span class="input-group-text bg-transparent">шт.</span>
                                            </div>
                                        </form>
                                    </div>

                                    <!-- Цена и сумма -->
                                    <div class="col-md-3">
                                        <div class="d-flex justify-content-between">
                                            <span class="text-muted">Цена:</span>
                                            <span class="fw-bold">@basketItem.Price.ToString("N0") ₽</span>
                                        </div>
                                        <div class="d-flex justify-content-between mt-2">
                                            <span class="text-muted">Сумма:</span>
                                            <span class="fw-bold text-success">@basketItem.Sum.ToString("N0") ₽</span>
                                        </div>
                                    </div>

                                    <!-- Удаление -->
                                    <div class="col-md-2 text-end">
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@basketItem.Id">
                                            <button type="submit"
                                                    class="btn btn-link text-danger"
                                                    title="Удалить">
                                                <i class="fas fa-trash-alt fa-lg"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Итоговая сумма -->
                    <div class="total-box m-4 p-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Общая сумма:</h5>
                            <h2 class="mb-0 text-light">@Model.Baskets.Sum(b => b.Sum).ToString("N0") ₽</h2>
                        </div>
                    </div>
                }
            </div>

            <!-- Футер с кнопками -->
            <div class="card-footer bg-transparent">
                <div class="d-flex justify-content-between align-items-center">
                    @if (Model.Baskets.Any())
                    {
                        <div class="d-flex gap-3">
                            <form method="post" asp-page-handler="Clear">
                                <button type="submit" class="btn btn-outline-mint">
                                    <i class="fas fa-eraser me-2"></i>Очистить
                                </button>
                            </form>
                            <a href="/UserDishs" class="btn btn-mint-outline">
                                <i class="fas fa-utensils me-2"></i>Добавить ещё
                            </a>
                        </div>

                        <form method="post" asp-page-handler="Order">
                            <button type="submit" class="btn btn-mint">
                                <i class="fas fa-check-circle me-2"></i>Оформить заказ
                            </button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-mint" asp-page="/UserDishs">
                            <i class="fas fa-arrow-left me-2"></i>Вернуться в меню
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

</body>

