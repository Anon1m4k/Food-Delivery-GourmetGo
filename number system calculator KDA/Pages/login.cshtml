@page
@model number_system_calculator_KDA.Pages.loginModel
@{
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Вход</title>
    
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css">
</head>
<body>
    <div class="container">
        <div class="row">
            
            <div class="col-md-12">
                
                <h2>Вход</h2>
                <p>Введите свою почту и пароль.</p>
                
                <form action="" method="post">

                    <div class="form-group">
                        <label>Электронная почта</label>
                        <input type="email" name="email" class="form-control" required />
                    </div>
                   
                    <div class="form-group">
                        <label>Пароль</label>
                        <input type="password" name="password" class="form-control" required>
                    </div>
                   
                    <div class="form-group">
                        <a class="btn btn-primary" asp-area="" asp-page="/Dishs">Вход</a>
                    </div>
                     
                    <p>Нет аккаунта? <a href="Profile">Создайте его за минуту</a>.</p>
                </form>
            </div>
        </div>
    </div>
</body>
</html>