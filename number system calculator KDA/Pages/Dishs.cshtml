@page
@model number_system_calculator_KDA.Pages.DishsModel
@{
}

<p>
    <a class="btn btn-primary" href="@Url.Page("Dish", new { id = 0 })">Добавить новое блюдо</a>
</p>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var dish in Model.Dishs)
    {
        <div class="col">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3">
                        <h5 class="card-title">@dish.Title</h5>
                        <h6 class="card-subtitle mb-2 text-muted small">@dish.Structure</h6>
                    </div>
                    <div class="mt-auto pt-2">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="d-flex align-items-center text-muted small">
                                <i class="fas fa-weight me-2"></i> @dish.Gram г
                            </span>
                            <span class="text-success fw-bold fs-4">
                                @dish.Price.ToString("N0") ₽
                            </span>
                        </div>
                        <div class="d-grid gap-2">
                            <a href="@Url.Page("Dish", new { id = dish.Id })" class="btn btn-warning">Изменить</a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@dish.Id"
                                  onsubmit="return confirm('Вы уверены, что хотите удалить это блюдо?');"
                                  class="w-100">
                                <button type="submit" class="btn btn-danger w-100">Удалить</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>