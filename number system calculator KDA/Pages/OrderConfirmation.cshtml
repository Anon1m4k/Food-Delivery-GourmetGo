@page
@model number_system_calculator_KDA.Pages.OrderConfirmationModel
@{
	ViewData["Title"] = "Подтверждение заказа";
}

<div class="container my-5">
    <div class="card border-0 shadow-lg">
        <div class="card-header bg-mint-500 text-white py-3">
            <h3 class="mb-0">
                <i class="fas fa-check-circle me-2"></i>Заказ принят
            </h3>
        </div>

        <div class="card-body p-4 text-center">
            <div class="mb-4">
                <i class="fas fa-box-open fa-4x text-mint-500 mb-3"></i>
                <h4 class="card-title">Номер вашего заказа</h4>
                <div class="display-4 text-mint-700 mb-3">#@Model.OrderId</div>
            </div>

            <p class="lead text-muted">
                Ваш заказ успешно оформлен!<br>
                Ожидайте звонка оператора для подтверждения деталей
            </p>

            <div class="mt-4">
                <a class="btn btn-primary btn-lg px-5"
                   asp-page="/UserDishs">
                    <i class="fas fa-utensils me-2"></i>Вернуться в меню
                </a>
            </div>
        </div>
    </div>
</div>

