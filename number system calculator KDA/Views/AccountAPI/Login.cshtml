@model number_system_calculator_KDA.Model.Login.LoginModel

<link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">

<div class="container" style="max-width: 480px;">
    <div class="card mt-5 border-0">
        <div class="card-body px-5 py-4">

            <h2>Вход на сайт</h2>

            <form method="post" asp-action="Login" asp-controller="Account">
                <div class="validation" asp-validation-summary="ModelOnly"></div>
                <div>
                    <div class="form-group">
                        <label asp-for="Email" class="control-label">Введите Email</label>
                        <input type="text" asp-for="Email" id="Email" name="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Password" class="control-label">Введите пароль</label>
                        <input asp-for="Password" type="password" id="Password" name="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <input type="submit" value="Войти" class="btn btn-success" />
                        <a href="/AccountAPI/Register" class="btn btn-primary btn-create ml-2">Регистрация</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>